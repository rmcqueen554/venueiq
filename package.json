{
  "name": "venueiq",
  "version": "1.0.0",
  "private": true,
  "description": "VenueIQ — AI-Powered Stadium Operations Intelligence Platform",
  "workspaces": [
    "packages/shared-types",
    "packages/shared-utils",
    "packages/kafka-schemas",
    "packages/frontend",
    "packages/services/tenant-service",
    "packages/services/executive-service",
    "packages/services/concessions-service",
    "packages/services/security-service",
    "packages/services/parking-service",
    "packages/services/facilities-service",
    "packages/services/agents-service",
    "packages/services/nlq-service",
    "packages/services/realtime-service",
    "packages/services/automation-service",
    "packages/services/reporting-service",
    "packages/services/ticketing-service",
    "packages/services/sponsorship-service",
    "packages/services/operations-service",
    "packages/services/merchandise-service",
    "packages/services/fan-experience-service"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:migrate": "turbo run db:migrate",
    "db:generate": "turbo run db:generate",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "setup:local": "bash infrastructure/scripts/setup-local.sh"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "prettier": "^3.2.0",
    "eslint": "^9.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
