{
  "name": "venueiq",
  "version": "1.0.0",
  "private": true,
  "description": "VenueIQ — AI-Powered Stadium Operations Intelligence Platform",
  "workspaces": [
    "packages/*",
    "packages/services/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:migrate": "turbo run db:migrate",
    "db:generate": "turbo run db:generate",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "setup:local": "bash infrastructure/scripts/setup-local.sh"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "prettier": "^3.2.0",
    "eslint": "^9.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
