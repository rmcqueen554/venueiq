# ============================================================
# VenueIQ — Required Environment Variables
# Copy this file to .env and fill in all values before running
# ============================================================

# App
NODE_ENV=development
PORT=3000

# Clerk (Auth)
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_WEBHOOK_SECRET=

# Databases (one per service)
TENANTS_DATABASE_URL=postgresql://venueiq:venueiq@localhost:5432/venueiq_tenants
EXECUTIVE_DATABASE_URL=postgresql://venueiq:venueiq@localhost:5433/venueiq_executive
CONCESSIONS_DATABASE_URL=postgresql://venueiq:venueiq@localhost:5434/venueiq_concessions
MERCHANDISE_DATABASE_URL=postgresql://venueiq:venueiq@localhost:5435/venueiq_merchandise
TICKETING_DATABASE_URL=postgresql://venueiq:venueiq@localhost:5436/venueiq_ticketing
SPONSORSHIP_DATABASE_URL=postgresql://venueiq:venueiq@localhost:5437/venueiq_sponsorship
OPERATIONS_DATABASE_URL=postgresql://venueiq:venueiq@localhost:5438/venueiq_operations
FACILITIES_DATABASE_URL=postgresql://venueiq:venueiq@localhost:5439/venueiq_facilities
SECURITY_DATABASE_URL=postgresql://venueiq:venueiq@localhost:5440/venueiq_security
PARKING_DATABASE_URL=postgresql://venueiq:venueiq@localhost:5441/venueiq_parking
FANS_DATABASE_URL=postgresql://venueiq:venueiq@localhost:5442/venueiq_fans
AGENTS_DATABASE_URL=postgresql://venueiq:venueiq@localhost:5443/venueiq_agents
NLQ_DATABASE_URL=postgresql://venueiq:venueiq@localhost:5444/venueiq_nlq
AUTOMATION_DATABASE_URL=postgresql://venueiq:venueiq@localhost:5445/venueiq_automation
REPORTING_DATABASE_URL=postgresql://venueiq:venueiq@localhost:5446/venueiq_reporting

# Redis
REDIS_URL=redis://localhost:6379

# Kafka (AWS MSK in prod, local Kafka in dev)
KAFKA_BROKERS=localhost:9092
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_SSL=false

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_REPORTS=venueiq-reports
S3_BUCKET_UPLOADS=venueiq-uploads
S3_BUCKET_ML_DATA=venueiq-ml-data
REDSHIFT_URL=
CLOUDFRONT_DOMAIN=

# Anthropic
ANTHROPIC_API_KEY=

# Pinecone (Vector DB)
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX_NAME=venueiq

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_API_KEY=

# Stripe (Billing)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_ENTERPRISE=

# Postmark (Email)
POSTMARK_API_TOKEN=
EMAIL_FROM_ADDRESS=noreply@venueiq.com
EMAIL_FROM_NAME=VenueIQ

# Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Firebase (Mobile Push)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Notifications
TEAMS_WEBHOOK_URL=
SLACK_WEBHOOK_URL=

# External Data APIs
TOMORROW_IO_API_KEY=
GOOGLE_MAPS_API_KEY=
MAPBOX_TOKEN=

# Connector OAuth Apps
TOAST_CLIENT_ID=
TOAST_CLIENT_SECRET=
SQUARE_APPLICATION_ID=
SQUARE_APPLICATION_SECRET=
TICKETMASTER_API_KEY=
AXS_CLIENT_ID=
AXS_CLIENT_SECRET=
SEATGEEK_CLIENT_ID=
SEATGEEK_CLIENT_SECRET=
PARKHUB_API_KEY=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
ADP_CLIENT_ID=
ADP_CLIENT_SECRET=
FIIX_API_KEY=

# ML Service
ML_SERVICE_URL=http://localhost:8000
ML_SERVICE_API_KEY=

# Datadog (Monitoring)
DATADOG_API_KEY=
DATADOG_APP_KEY=
DD_SERVICE=venueiq
DD_ENV=development
