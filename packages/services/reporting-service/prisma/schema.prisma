generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("REPORTING_DATABASE_URL")
}

model Report {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id    String    @db.Uuid
  type         String    // executive_summary|event_performance|department|sponsor_partner|board|custom
  title        String
  module       String?   // which module this report covers
  event_id     String?   @db.Uuid
  status       String    @default("pending") // pending|generating|completed|failed
  format       String    @default("pdf") // pdf|excel|csv|html
  s3_url       String?
  file_size_bytes Int?
  generated_by String?   // Clerk user ID or 'system'
  parameters   Json?     // report-specific filters
  schedule_id  String?   @db.Uuid
  created_at   DateTime  @default(now()) @db.Timestamptz
  completed_at DateTime? @db.Timestamptz

  deliveries ReportDelivery[]

  @@index([tenant_id, type])
  @@index([tenant_id, created_at])
  @@map("reports")
}

model ReportDelivery {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id    String    @db.Uuid
  report_id    String    @db.Uuid
  channel      String    // email|teams|slack|s3
  recipient    String
  delivered_at DateTime? @db.Timestamptz
  status       String    @default("pending")
  created_at   DateTime  @default(now()) @db.Timestamptz

  report Report @relation(fields: [report_id], references: [id])

  @@index([tenant_id, report_id])
  @@map("report_deliveries")
}

model ReportSchedule {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id   String    @db.Uuid
  name        String
  report_type String
  cron_expr   String
  recipients  Json      // string[]
  channels    Json      // string[]
  parameters  Json?
  active      Boolean   @default(true)
  last_run_at DateTime? @db.Timestamptz
  created_at  DateTime  @default(now()) @db.Timestamptz
  updated_at  DateTime  @updatedAt @db.Timestamptz

  @@index([tenant_id])
  @@map("report_schedules")
}
