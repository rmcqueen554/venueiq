generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("EXECUTIVE_DATABASE_URL")
}

model DailyBriefing {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id    String   @db.Uuid
  content      String
  event_id     String?  @db.Uuid
  briefing_date DateTime @db.Date
  delivered    Boolean  @default(false)
  token_count  Int?
  cost_usd     Decimal? @db.Decimal(8, 6)
  created_at   DateTime @default(now()) @db.Timestamptz

  @@unique([tenant_id, briefing_date])
  @@index([tenant_id])
  @@map("daily_briefings")
}

model RevenueForecast {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id          String   @db.Uuid
  event_id           String   @db.Uuid
  total_forecast     Decimal  @db.Decimal(12, 2)
  confidence_lower   Decimal  @db.Decimal(12, 2)
  confidence_upper   Decimal  @db.Decimal(12, 2)
  by_stream          Json     // { ticketing, concessions, merchandise, parking, sponsorship }
  model_version      String
  created_at         DateTime @default(now()) @db.Timestamptz

  @@unique([tenant_id, event_id])
  @@index([tenant_id])
  @@map("revenue_forecasts")
}

model KpiSnapshot {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id   String   @db.Uuid
  event_id    String?  @db.Uuid
  module      String
  kpis        Json
  snapshot_at DateTime @db.Timestamptz
  created_at  DateTime @default(now()) @db.Timestamptz

  @@index([tenant_id, module, snapshot_at])
  @@map("kpi_snapshots")
}

model RiskOpportunity {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id          String    @db.Uuid
  event_id           String?   @db.Uuid
  severity           String    // critical|high|medium|low
  module             String
  title              String
  description        String
  recommended_action String
  dismissed          Boolean   @default(false)
  acted_on           Boolean   @default(false)
  acted_by           String?
  acted_at           DateTime? @db.Timestamptz
  expires_at         DateTime? @db.Timestamptz
  created_at         DateTime  @default(now()) @db.Timestamptz

  @@index([tenant_id, dismissed, created_at])
  @@map("risk_opportunities")
}
