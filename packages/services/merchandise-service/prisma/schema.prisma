generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("MERCHANDISE_DATABASE_URL")
}

model MerchLocation {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String   @db.Uuid
  venue_id   String   @db.Uuid
  name       String
  type       String   // permanent|popup|online
  location_x Float    @default(0)
  location_y Float    @default(0)
  active     Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @updatedAt @db.Timestamptz

  @@index([tenant_id])
  @@map("merch_locations")
}

model MerchProduct {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id        String   @db.Uuid
  name             String
  category         String   // apparel|headwear|collectible|novelty|online_exclusive|event_specific
  price            Decimal  @db.Decimal(10, 2)
  cost             Decimal  @db.Decimal(10, 2)
  sku              String
  is_event_specific Boolean @default(false)
  event_id         String?  @db.Uuid
  active           Boolean  @default(true)
  image_url        String?
  created_at       DateTime @default(now()) @db.Timestamptz
  updated_at       DateTime @updatedAt @db.Timestamptz

  @@unique([tenant_id, sku])
  @@index([tenant_id])
  @@map("merch_products")
}

model MerchInventory {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id   String   @db.Uuid
  location_id String   @db.Uuid
  product_id  String   @db.Uuid
  quantity    Int      @default(0)
  par_level   Int      @default(20)
  updated_at  DateTime @updatedAt @db.Timestamptz
  created_at  DateTime @default(now()) @db.Timestamptz

  @@unique([tenant_id, location_id, product_id])
  @@index([tenant_id])
  @@map("merch_inventory")
}

model MerchTransaction {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id      String   @db.Uuid
  location_id    String   @db.Uuid
  product_id     String   @db.Uuid
  quantity       Int
  price          Decimal  @db.Decimal(10, 2)
  fan_id         String?  @db.Uuid
  event_id       String   @db.Uuid
  transaction_id String
  source_system  String
  occurred_at    DateTime @db.Timestamptz
  created_at     DateTime @default(now()) @db.Timestamptz

  @@index([tenant_id, event_id])
  @@index([tenant_id, location_id, occurred_at])
  @@map("merch_transactions")
}

model MerchForecast {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id          String   @db.Uuid
  event_id           String   @db.Uuid
  product_id         String   @db.Uuid
  forecasted_units   Int
  forecasted_revenue Decimal  @db.Decimal(10, 2)
  model_version      String
  created_at         DateTime @default(now()) @db.Timestamptz

  @@unique([tenant_id, event_id, product_id])
  @@index([tenant_id, event_id])
  @@map("merch_forecasts")
}
