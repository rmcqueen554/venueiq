generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("SECURITY_DATABASE_URL")
}

model SecurityIncident {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id            String    @db.Uuid
  event_id             String    @db.Uuid
  type                 String    // fight|medical|theft|ejection|suspicious_item|crowd_crush_risk|other
  severity             String    // critical|high|medium|low
  location_description String
  location_x           Float?
  location_y           Float?
  reported_at          DateTime  @db.Timestamptz
  resolved_at          DateTime? @db.Timestamptz
  reported_by          String    // Clerk user ID
  description          String
  actions_taken        Json      @default("[]") // IncidentAction[]
  status               String    @default("open") // open|contained|closed
  created_at           DateTime  @default(now()) @db.Timestamptz
  updated_at           DateTime  @updatedAt @db.Timestamptz

  @@index([tenant_id, event_id])
  @@index([tenant_id, severity])
  @@index([tenant_id, status])
  @@map("security_incidents")
}

// TimescaleDB hypertable
model AccessEvent {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id      String   @db.Uuid
  gate_id        String
  gate_name      String
  credential_id  String
  fan_id         String?  @db.Uuid
  event_type     String   // entry|exit|denied|forced
  ticket_type    String?
  section        String?
  occurred_at    DateTime @db.Timestamptz
  created_at     DateTime @default(now()) @db.Timestamptz

  @@index([tenant_id, occurred_at])
  @@index([tenant_id, gate_id, occurred_at])
  @@map("access_events")
}

model SecurityPost {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id       String    @db.Uuid
  event_id        String    @db.Uuid
  post_name       String
  location        String
  location_x      Float?
  location_y      Float?
  assigned_staff  String?   // Clerk user ID
  check_in_time   DateTime? @db.Timestamptz
  check_out_time  DateTime? @db.Timestamptz
  created_at      DateTime  @default(now()) @db.Timestamptz
  updated_at      DateTime  @updatedAt @db.Timestamptz

  @@index([tenant_id, event_id])
  @@map("security_posts")
}

model CameraFeed {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id         String   @db.Uuid
  name              String
  location_x        Float    @default(0)
  location_y        Float    @default(0)
  stream_url        String?
  analytics_enabled Boolean  @default(false)
  zone_id           String?  @db.Uuid
  active            Boolean  @default(true)
  created_at        DateTime @default(now()) @db.Timestamptz
  updated_at        DateTime @updatedAt @db.Timestamptz

  @@index([tenant_id])
  @@map("camera_feeds")
}

// TimescaleDB hypertable
model CrowdDensityReading {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id     String   @db.Uuid
  zone_id       String   @db.Uuid
  zone_name     String
  density_level Int      // 0-100
  alert_level   String   @default("normal") // normal|warning|critical
  occurred_at   DateTime @db.Timestamptz
  created_at    DateTime @default(now()) @db.Timestamptz

  @@index([tenant_id, zone_id, occurred_at])
  @@map("crowd_density_readings")
}

model BannedPatron {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id   String    @db.Uuid
  name        String
  photo_url   String?
  ban_reason  String
  ban_date    DateTime  @db.Timestamptz
  ban_expiry  DateTime? @db.Timestamptz
  active      Boolean   @default(true)
  created_at  DateTime  @default(now()) @db.Timestamptz
  updated_at  DateTime  @updatedAt @db.Timestamptz

  @@index([tenant_id])
  @@map("banned_patrons")
}

model EmergencyPlan {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id    String   @db.Uuid
  scenario     String   // medical|evacuation|severe_weather|active_threat|fire
  title        String
  content      String   // Markdown runbook content
  version      Int      @default(1)
  document_url String?
  active       Boolean  @default(true)
  created_at   DateTime @default(now()) @db.Timestamptz
  updated_at   DateTime @updatedAt @db.Timestamptz

  @@index([tenant_id])
  @@map("emergency_plans")
}
