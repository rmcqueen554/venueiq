generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("TENANTS_DATABASE_URL")
}

model Tenant {
  id                      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                    String
  slug                    String    @unique
  type                    String    // stadium|arena|amphitheater|civic_center|racetrack|fairground|convention_center
  capacity                Int?
  timezone                String
  tier                    String    @default("starter") // starter|professional|enterprise
  stripe_customer_id      String?
  stripe_subscription_id  String?
  white_label_config      Json?     // WhiteLabelConfig
  onboarding_completed_at DateTime? @db.Timestamptz
  created_at              DateTime  @default(now()) @db.Timestamptz
  updated_at              DateTime  @updatedAt @db.Timestamptz

  venues       Venue[]
  events       Event[]
  data_sources TenantDataSource[]
  users        TenantUser[]

  @@map("tenants")
}

model Venue {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id     String   @db.Uuid
  name          String
  address       String?
  city          String?
  state         String?
  country       String   @default("US")
  lat           Decimal? @db.Decimal(9, 6)
  lng           Decimal? @db.Decimal(9, 6)
  layout_config Json?    // VenueLayoutConfig
  created_at    DateTime @default(now()) @db.Timestamptz
  updated_at    DateTime @updatedAt @db.Timestamptz

  tenant Tenant  @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  events Event[]

  @@index([tenant_id])
  @@map("venues")
}

model Event {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id            String    @db.Uuid
  venue_id             String    @db.Uuid
  name                 String
  type                 String    // game|concert|convention|private|rehearsal
  sport_or_genre       String?
  opponent_or_artist   String?
  scheduled_at         DateTime  @db.Timestamptz
  gates_open_at        DateTime? @db.Timestamptz
  expected_attendance  Int?
  status               String    @default("scheduled") // scheduled|live|completed|cancelled
  weather_forecast     Json?
  revenue_forecast     Json?
  created_at           DateTime  @default(now()) @db.Timestamptz
  updated_at           DateTime  @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  venue  Venue  @relation(fields: [venue_id], references: [id])

  @@index([tenant_id])
  @@index([tenant_id, status])
  @@index([tenant_id, scheduled_at])
  @@map("events")
}

model TenantDataSource {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id     String    @db.Uuid
  source_type   String    // DataSourceType
  credentials   Json      // encrypted at rest via AWS KMS in production
  status        String    @default("pending") // connected|disconnected|error|pending
  last_sync_at  DateTime? @db.Timestamptz
  error_message String?
  webhook_url   String?   // for webhook-based connectors
  config        Json?     // additional connector-specific config
  created_at    DateTime  @default(now()) @db.Timestamptz
  updated_at    DateTime  @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, source_type])
  @@index([tenant_id])
  @@map("tenant_data_sources")
}

model TenantUser {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id    String    @db.Uuid
  user_id      String    // Clerk user ID
  role         String    // UserRole enum
  permissions  Json      @default("{}")
  invited_at   DateTime  @default(now()) @db.Timestamptz
  activated_at DateTime? @db.Timestamptz
  created_at   DateTime  @default(now()) @db.Timestamptz
  updated_at   DateTime  @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, user_id])
  @@index([tenant_id])
  @@index([user_id])
  @@map("tenant_users")
}

model OnboardingProgress {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id   String   @unique @db.Uuid
  step        Int      @default(1) // 1-7
  completed   Boolean  @default(false)
  step_data   Json     @default("{}")
  created_at  DateTime @default(now()) @db.Timestamptz
  updated_at  DateTime @updatedAt @db.Timestamptz

  @@map("onboarding_progress")
}

model NotificationConfig {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id        String   @unique @db.Uuid
  preferred_channel String  @default("teams") // teams|slack
  teams_webhook    String?
  slack_webhook    String?
  email_enabled    Boolean  @default(true)
  sms_enabled      Boolean  @default(false)
  created_at       DateTime @default(now()) @db.Timestamptz
  updated_at       DateTime @updatedAt @db.Timestamptz

  @@map("notification_configs")
}
