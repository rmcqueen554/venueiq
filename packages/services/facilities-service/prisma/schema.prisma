generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("FACILITIES_DATABASE_URL")
}

model Asset {
  id                       String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id                String    @db.Uuid
  name                     String
  type                     String    // hvac|elevator|generator|scoreboard|lighting|plumbing|electrical|other
  location_id              String?   @db.Uuid
  location_name            String?
  manufacturer             String?
  model                    String?
  serial                   String?
  install_date             DateTime? @db.Timestamptz
  warranty_expiry          DateTime? @db.Timestamptz
  last_maintenance         DateTime? @db.Timestamptz
  maintenance_interval_days Int      @default(90)
  health_score             Float     @default(1.0)
  failure_probability      Float     @default(0.0)
  failure_days_estimate    Int?
  active                   Boolean   @default(true)
  created_at               DateTime  @default(now()) @db.Timestamptz
  updated_at               DateTime  @updatedAt @db.Timestamptz

  work_orders MaintenanceWorkOrder[]

  @@index([tenant_id])
  @@index([tenant_id, type])
  @@map("assets")
}

model MaintenanceWorkOrder {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id    String    @db.Uuid
  asset_id     String    @db.Uuid
  type         String    // preventive|corrective|predictive
  description  String
  priority     String    @default("medium") // critical|high|medium|low
  status       String    @default("open") // open|in_progress|completed|cancelled
  assigned_to  String?
  scheduled_at DateTime? @db.Timestamptz
  completed_at DateTime? @db.Timestamptz
  cost         Decimal?  @db.Decimal(10, 2)
  cmms_ref     String?   // external CMMS work order reference
  notes        String?
  created_at   DateTime  @default(now()) @db.Timestamptz
  updated_at   DateTime  @updatedAt @db.Timestamptz

  asset Asset @relation(fields: [asset_id], references: [id])

  @@index([tenant_id])
  @@index([tenant_id, status])
  @@index([tenant_id, asset_id])
  @@map("maintenance_work_orders")
}

// TimescaleDB hypertable — created via raw SQL migration
model IotSensorReading {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id   String   @db.Uuid
  asset_id    String   @db.Uuid
  metric_name String
  value       Float
  unit        String
  zone_id     String?  @db.Uuid
  occurred_at DateTime @db.Timestamptz
  created_at  DateTime @default(now()) @db.Timestamptz

  @@index([tenant_id, asset_id, occurred_at])
  @@index([tenant_id, occurred_at])
  @@map("iot_sensor_readings")
}

// TimescaleDB hypertable
model EnergyReading {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id   String   @db.Uuid
  zone_id     String   @db.Uuid
  zone_name   String
  kwh         Float
  cost        Decimal  @db.Decimal(10, 4)
  occurred_at DateTime @db.Timestamptz
  created_at  DateTime @default(now()) @db.Timestamptz

  @@index([tenant_id, zone_id, occurred_at])
  @@map("energy_readings")
}

model Inspection {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id      String    @db.Uuid
  type           String    // fire|elevator|electrical|structural|health
  last_completed DateTime? @db.Timestamptz
  next_due       DateTime  @db.Timestamptz
  status         String    @default("current") // current|due_soon|overdue
  inspector      String?
  certificate_url String?
  notes          String?
  created_at     DateTime  @default(now()) @db.Timestamptz
  updated_at     DateTime  @updatedAt @db.Timestamptz

  @@index([tenant_id])
  @@index([tenant_id, next_due])
  @@map("inspections")
}

model FacilityZone {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id   String   @db.Uuid
  venue_id    String   @db.Uuid
  name        String
  type        String   // concourse|suite|field|parking|entry|service
  capacity    Int
  location_x  Float    @default(0)
  location_y  Float    @default(0)
  created_at  DateTime @default(now()) @db.Timestamptz

  @@index([tenant_id])
  @@map("facility_zones")
}
