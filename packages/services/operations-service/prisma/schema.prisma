generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("OPERATIONS_DATABASE_URL")
}

model StaffSchedule {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id       String    @db.Uuid
  event_id        String    @db.Uuid
  department      String    // concessions|merchandise|security|parking|facilities|admin|entertainment
  employee_id     String
  employee_name   String?
  scheduled_start DateTime  @db.Timestamptz
  scheduled_end   DateTime  @db.Timestamptz
  actual_start    DateTime? @db.Timestamptz
  actual_end      DateTime? @db.Timestamptz
  overtime_hours  Float     @default(0)
  hourly_rate     Decimal   @db.Decimal(8, 2)
  source_system   String    @default("manual") // adp|ukg|when_i_work|manual
  created_at      DateTime  @default(now()) @db.Timestamptz
  updated_at      DateTime  @updatedAt @db.Timestamptz

  @@index([tenant_id, event_id])
  @@index([tenant_id, department])
  @@map("staff_schedules")
}

model VendorContract {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id      String   @db.Uuid
  vendor_name    String
  service_type   String   // catering|security|cleaning|maintenance|entertainment|technology|other
  contract_value Decimal  @db.Decimal(12, 2)
  start_date     DateTime @db.Timestamptz
  end_date       DateTime @db.Timestamptz
  sla_terms      Json
  contact_email  String?
  contact_name   String?
  notes          String?
  active         Boolean  @default(true)
  created_at     DateTime @default(now()) @db.Timestamptz
  updated_at     DateTime @updatedAt @db.Timestamptz

  performance_records VendorPerformance[]

  @@index([tenant_id])
  @@map("vendor_contracts")
}

model VendorPerformance {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id      String   @db.Uuid
  vendor_id      String   @db.Uuid
  event_id       String   @db.Uuid
  sla_met        Boolean
  quality_score  Float    // 0-10
  cost_variance  Decimal  @db.Decimal(10, 2)
  notes          String?
  scored_by      String?
  created_at     DateTime @default(now()) @db.Timestamptz

  vendor VendorContract @relation(fields: [vendor_id], references: [id])

  @@index([tenant_id, vendor_id])
  @@index([tenant_id, event_id])
  @@map("vendor_performance")
}

model OperationalAlert {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id          String    @db.Uuid
  event_id           String?   @db.Uuid
  module             String
  severity           String    // critical|high|medium|low
  title              String
  description        String
  recommended_action String?
  resolved_at        DateTime? @db.Timestamptz
  resolved_by        String?
  dismissed          Boolean   @default(false)
  created_at         DateTime  @default(now()) @db.Timestamptz

  @@index([tenant_id, event_id])
  @@index([tenant_id, severity, resolved_at])
  @@map("operational_alerts")
}

// TimescaleDB hypertable
model ZoneOccupancy {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id       String   @db.Uuid
  zone_id         String   @db.Uuid
  zone_name       String
  occupancy_count Int
  occurred_at     DateTime @db.Timestamptz
  created_at      DateTime @default(now()) @db.Timestamptz

  @@index([tenant_id, zone_id, occurred_at])
  @@map("zone_occupancy")
}

model DepartmentBudget {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id    String   @db.Uuid
  event_id     String   @db.Uuid
  department   String
  budgeted     Decimal  @db.Decimal(12, 2)
  actual       Decimal  @default(0) @db.Decimal(12, 2)
  variance     Decimal  @default(0) @db.Decimal(12, 2)
  created_at   DateTime @default(now()) @db.Timestamptz
  updated_at   DateTime @updatedAt @db.Timestamptz

  @@unique([tenant_id, event_id, department])
  @@index([tenant_id, event_id])
  @@map("department_budgets")
}
