{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SecurityIncidentEvent",
  "type": "object",
  "required": ["schema_version","tenant_id","event_id","incident_id","incident_type","severity","location_description","reported_by","occurred_at"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "tenant_id": { "type": "string", "format": "uuid" },
    "event_id": { "type": "string", "format": "uuid" },
    "incident_id": { "type": "string", "format": "uuid" },
    "incident_type": { "type": "string", "enum": ["fight","medical","theft","ejection","suspicious_item","crowd_crush_risk","other"] },
    "severity": { "type": "string", "enum": ["critical","high","medium","low"] },
    "location_description": { "type": "string" },
    "location_x": { "type": ["number","null"] },
    "location_y": { "type": ["number","null"] },
    "reported_by": { "type": "string" },
    "occurred_at": { "type": "string", "format": "date-time" }
  }
}
